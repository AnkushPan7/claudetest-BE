# PostgreSQL (local docker-compose or Render Internal URL)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=claudecert;Username=claudecert;Password=claudecert

# Admin seed (created on first startup if missing)
Auth__AdminEmail=admin@appunik.com
Auth__AdminPassword=ChangeMe@123#

# JWT signing key — use a random 32+ character string in production
Auth__JwtSecret=change-this-to-a-long-random-secret-in-production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Render PostgreSQL alternative (auto-parsed if DefaultConnection is empty)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CORS (comma-separated origins for production)
# CORS_ALLOWED_ORIGINS=https://claudetest-fe.onrender.com
